# Estatics Ballers - Variáveis de Ambiente
# Copie para .env e preencha com suas chaves

# APIs de dados (obrigatórias)
FOOTBALL_DATA_API_KEY=seu_token_aqui
THE_ODDS_API_KEY=seu_token_aqui

# LLM - use uma das opções abaixo
GROQ_API_KEY=seu_token_aqui
# OU
OPENAI_API_KEY=seu_token_aqui
# OU
ANTHROPIC_API_KEY=seu_token_aqui

# Provedor preferido: groq, openai ou anthropic
LLM_PROVIDER=groq

# Notificações Telegram (opcional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Configuração
OUTPUT_DIR=./reports
LOG_LEVEL=INFO
